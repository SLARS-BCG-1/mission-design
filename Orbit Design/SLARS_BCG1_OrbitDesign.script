SLARS_BCG_1.NAIFIdReferenceFrame = -9001001;
SLARS_BCG_1.OrbitColor = Red;
SLARS_BCG_1.TargetColor = Teal;
SLARS_BCG_1.OrbitErrorCovariance = [ 1e+70 0 0 0 0 0 ; 0 1e+70 0 0 0 0 ; 0 0 1e+70 0 0 0 ; 0 0 0 1e+70 0 0 ; 0 0 0 0 1e+70 0 ; 0 0 0 0 0 1e+70 ];
SLARS_BCG_1.CdSigma = 1e+70;
SLARS_BCG_1.CrSigma = 1e+70;
