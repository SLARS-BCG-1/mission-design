SLARS_BCG_1.SPADDragScaleFactorSigma = 1e+70;
SLARS_BCG_1.AtmosDensityScaleFactorSigma = 1e+70;
SLARS_BCG_1.ModelFile = 'aura.3ds';
SLARS_BCG_1.ModelOffsetX = 0;
SLARS_BCG_1.ModelOffsetY = 0;
SLARS_BCG_1.ModelOffsetZ = 0;
